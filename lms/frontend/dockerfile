# Stage 1: Build Vite React app
FROM node:20-alpine AS build

WORKDIR /app

# Install bash & findutils for scripts
RUN apk add --no-cache bash findutils util-linux

# Copy package files and install dependencies
COPY package*.json ./
RUN if [ -f package-lock.json ]; then \
      npm ci; \
    else \
      npm install; \
    fi

# Copy the rest of the frontend source code
COPY . .

# Normalize all file/folder names to lowercase to avoid case-sensitive import issues
RUN find . -depth | while read path; do \
      lower=$(echo "$path" | tr 'A-Z' 'a-z'); \
      if [ "$path" != "$lower" ]; then \
        mkdir -p "$(dirname "$lower")" && mv "$path" "$lower"; \
      fi \
    ; done

# Build for production
RUN npm run build

# Stage 2: Serve with Nginx
FROM nginx:stable-alpine

# Copy build output to nginx html folder
COPY --from=build /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose HTTP port
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
