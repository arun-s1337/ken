# Stage 1: build + lint
FROM node:20-alpine AS build
WORKDIR /app

# Install tools to fix case issues (util-linux provides rename)
RUN apk add --no-cache bash findutils util-linux

# Copy package files and install deps
COPY package*.json ./
RUN npm ci

# Copy all source files
COPY . .

# Normalize file & folder names to lowercase inside the container
RUN find . -depth | while read path; do \
    lower=$(echo "$path" | tr 'A-Z' 'a-z'); \
    if [ "$path" != "$lower" ]; then \
        mkdir -p "$(dirname "$lower")" && mv "$path" "$lower"; \
    fi \
; done

# Run lint (optional)
RUN npm run lint || echo "⚠️ Lint warnings ignored due to case fix"

# Build project
RUN npm run build

# Stage 2: serve
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY ../nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
