FROM node:20-alpine
WORKDIR /app

# Tools for case normalization
RUN apk add --no-cache bash findutils util-linux

# Install only production deps
COPY package*.json ./
RUN if [ -f package-lock.json ]; then \
      npm ci --omit=dev; \
    else \
      npm install --omit=dev; \
    fi

# Copy source
COPY . .

# Normalize all file/folder names to lowercase (fixes Linux case errors)
RUN find . -depth | while read path; do \
      lower=$(echo "$path" | tr 'A-Z' 'a-z'); \
      if [ "$path" != "$lower" ]; then \
        mkdir -p "$(dirname "$lower")" && mv "$path" "$lower"; \
      fi \
    ; done

ENV NODE_ENV=production
ENV PORT=5000
EXPOSE 5000

# If your entry file is not server.js, change it here
CMD ["node", "server.js"]
