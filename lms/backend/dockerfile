FROM node:20-alpine
WORKDIR /app

# Install tools for case normalization
RUN apk add --no-cache bash findutils util-linux

COPY package*.json ./

RUN if [ -f package-lock.json ]; then \
      npm ci --omit=dev; \
    else \
      npm install --omit=dev; \
    fi

COPY . .

# Normalize to lowercase
RUN find . -depth | while read path; do \
      lower=$(echo "$path" | tr 'A-Z' 'a-z'); \
      if [ "$path" != "$lower" ]; then \
          mkdir -p "$(dirname "$lower")" && mv "$path" "$lower"; \
      fi \
    ; done

ENV NODE_ENV=production
ENV PORT=5000
EXPOSE 5000
CMD ["node", "server.js"]
